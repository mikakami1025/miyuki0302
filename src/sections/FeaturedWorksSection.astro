---
import { workCollections } from '@/data/home';

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const featuredWorks = [
  ...workCollections[0].slides.slice(0, 3).map((slide) => ({ ...slide, collection: workCollections[0].title })),
  ...workCollections[1].slides.slice(0, 2).map((slide) => ({ ...slide, collection: workCollections[1].title }))
];
---

<section class="section featured-works-section" aria-labelledby="featured-works-title">
  <div class="container">
    <div class="section-heading section-heading--center">
      <p class="eyebrow">Selected Works</p>
      <h2 id="featured-works-title">精選學生作品</h2>
    </div>
    <div class="featured-works">
      {featuredWorks.map((work, index) => (
        <figure class={`featured-work featured-work--${index + 1}`}>
          <a href={asset(work.image)} target="_blank" rel="noreferrer" aria-label={`${work.title}，開啟大圖觀看`}>
            <img
              src={asset(work.image)}
              alt={`${work.title}｜${work.collection}精選學生作品`}
              width="1200"
              height="900"
              loading={index === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          </a>
          <figcaption>
            <span>{work.collection}</span>
            <strong>{work.title}</strong>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>
