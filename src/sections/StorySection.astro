---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const hrefFor = (href: string) => `${base}${href.replace(/^\/+/, '')}`;
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<section class="section story-section" aria-labelledby="story-title">
  <div class="container story-layout">
    <div class="section-heading section-heading--left">
      <p class="eyebrow">Stories</p>
      <h2 id="story-title">文章／創作故事</h2>
    </div>
    <div class="story-list">
      {posts.map((post) => (
        <article class="story-item">
          <a href={hrefFor(`blog/${post.data.slug}/`)}>
            <img
              src={asset(post.data.cover)}
              alt={`${post.data.title}｜Miyuki老師與學生作品故事`}
              width="720"
              height="540"
              loading="lazy"
              decoding="async"
            />
            <div>
              <p class="post-meta">
                <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('zh-TW')}</time>
                <span>{post.data.category}</span>
              </p>
              <h3>{post.data.title}</h3>
              <p>{post.data.description}</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
