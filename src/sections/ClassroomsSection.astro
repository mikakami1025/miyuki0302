---
import { classrooms } from '@/data/classrooms';
---

<section class="section classrooms-section" id="classrooms">
  <div class="container">
    <div class="section-heading section-heading--center">
      <p class="eyebrow">Madoka Flower Design School</p>
      <h2>
        日本MADOKA
        <br />
        花藝設計學院認證教室資訊
      </h2>
    </div>
    <div class="classroom-list">
      {classrooms.map((group) => (
        <details class="classroom-card">
          <summary>
            <span>
              <strong>{group.city}</strong>
              <small>{group.summary}</small>
            </span>
            <span class="summary-icon">＋</span>
          </summary>
          <div class="school-list">
            {group.schools.map((school) => (
              <article class="school-item">
                <h3>{school.name}</h3>
                <p>{school.teacher}</p>
                <p>{school.address}</p>
                <p>{school.phone}</p>
                <small>{school.note}</small>
              </article>
            ))}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
