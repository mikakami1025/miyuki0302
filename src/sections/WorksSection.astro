---
import SectionHeading from '@/components/common/SectionHeading.astro';
import WorkCarousel from '@/components/home/WorkCarousel.astro';
import { workCollections } from '@/data/home';
---

<section class="section works-section" id="works">
  <div class="container">
    <SectionHeading
      eyebrow="Collections"
      title="作品分類入口"
    />
    <div class="works-grid">
      {workCollections.map((collection) => <WorkCarousel collection={collection} />)}
    </div>
  </div>
</section>
