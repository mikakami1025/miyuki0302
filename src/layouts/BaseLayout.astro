---
import '../styles/global.css';
import { siteConfig } from '@/config/site';
import { contactInfo } from '@/data/contact';

type Props = {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
};

const {
  title = siteConfig.name,
  description = siteConfig.description,
  image = siteConfig.background.image,
  type = 'website'
} = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const hrefFor = (href: string) => {
  if (href.startsWith('http') || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) {
    return href;
  }
  return `${base}${href.replace(/^\/+/, '')}`;
};
const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.shortName}`;
const canonicalUrl = Astro.url.toString();
const ogImage = new URL(asset(image), Astro.site || canonicalUrl).toString();
const siteRoot = new URL(base, Astro.site || canonicalUrl).toString();
const logoUrl = new URL(asset(siteConfig.logo), Astro.site || canonicalUrl).toString();
const sameAs = [...new Set((contactInfo.socialLinks ?? [])
  .map((link) => link.url)
  .filter(Boolean))];
const schemaGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteRoot}#person`,
      name: '林美雪(Miyuki)',
      alternateName: ['Miyuki', siteConfig.shortName],
      jobTitle: '日本水晶花藝教授',
      url: siteRoot,
      image: logoUrl,
      email: contactInfo.email,
      telephone: contactInfo.phone,
      sameAs,
      worksFor: { '@id': `${siteRoot}#educational-organization` },
      knowsAbout: ['日本水晶花藝', 'アメリカンフラワー', 'American Flower', '工藝盆栽', 'MADOKA水晶花國際認證']
    },
    {
      '@type': 'EducationalOrganization',
      '@id': `${siteRoot}#educational-organization`,
      name: siteConfig.name,
      url: siteRoot,
      logo: logoUrl,
      email: contactInfo.email,
      telephone: contactInfo.phone,
      sameAs,
      address: {
        '@type': 'PostalAddress',
        streetAddress: contactInfo.address,
        addressLocality: '高雄市',
        addressRegion: '高雄市',
        addressCountry: 'TW'
      }
    },
    {
      '@type': 'LocalBusiness',
      '@id': `${siteRoot}#local-business`,
      name: siteConfig.shortName,
      url: siteRoot,
      image: ogImage,
      email: contactInfo.email,
      telephone: contactInfo.phone,
      sameAs,
      address: {
        '@type': 'PostalAddress',
        streetAddress: contactInfo.address,
        addressLocality: '高雄市',
        addressRegion: '高雄市',
        addressCountry: 'TW'
      },
      areaServed: ['台灣', '香港']
    }
  ]
};
---

<!doctype html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>
    <link rel="icon" href={asset(siteConfig.logo)} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script type="application/ld+json" is:inline set:html={JSON.stringify(schemaGraph)} />
  </head>
  <body style={`--site-bg-image: url('${asset(siteConfig.background.image)}'); --site-bg-overlay: ${siteConfig.background.overlay};`}>
    <header class="site-header">
      <a class="brand" href={base} aria-label={siteConfig.shortName}>
        <img src={asset(siteConfig.logo)} alt={siteConfig.shortName} width="48" height="48" />
        <span>{siteConfig.shortName}</span>
      </a>
      <nav class="site-nav" aria-label="主要導覽">
        {siteConfig.nav.map((item) => <a href={hrefFor(item.href)}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>{siteConfig.name}</p>
      <p>American Flower & Ctaft bonsai art</p>
    </footer>
    <script>
      document.querySelectorAll('.classroom-card').forEach((card) => {
        card.addEventListener('toggle', () => {
          if (!(card instanceof HTMLDetailsElement) || !card.open) return;
          document.querySelectorAll('.classroom-card[open]').forEach((openedCard) => {
            if (openedCard !== card && openedCard instanceof HTMLDetailsElement) {
              openedCard.open = false;
            }
          });
        });
      });
    </script>
  </body>
</html>
