---
import '../styles/global.css';
import { siteConfig } from '@/config/site';

type Props = {
  title?: string;
  description?: string;
  image?: string;
  type?: 'website' | 'article';
};

const {
  title = siteConfig.name,
  description = siteConfig.description,
  image = siteConfig.background.image,
  type = 'website'
} = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const hrefFor = (href: string) => {
  if (href.startsWith('http') || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) {
    return href;
  }
  return `${base}${href.replace(/^\/+/, '')}`;
};
const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.shortName}`;
const canonicalUrl = Astro.url.toString();
const ogImage = new URL(asset(image), Astro.site || canonicalUrl).toString();
---

<!doctype html>
<html lang={siteConfig.locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={canonicalUrl} />
    <title>{pageTitle}</title>
    <link rel="icon" href={asset(siteConfig.logo)} />
    <meta property="og:locale" content="zh_TW" />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:type" content={type} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body style={`--site-bg-image: url('${asset(siteConfig.background.image)}'); --site-bg-overlay: ${siteConfig.background.overlay};`}>
    <header class="site-header">
      <a class="brand" href={base} aria-label={siteConfig.shortName}>
        <img src={asset(siteConfig.logo)} alt={siteConfig.shortName} width="48" height="48" />
        <span>{siteConfig.shortName}</span>
      </a>
      <nav class="site-nav" aria-label="主要導覽">
        {siteConfig.nav.map((item) => <a href={hrefFor(item.href)}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <p>{siteConfig.name}</p>
      <p>Crystal flower, craft bonsai and handmade botanical stories.</p>
    </footer>
    <script>
      document.querySelectorAll('[data-carousel]').forEach((carousel) => {
        const track = carousel.querySelector('[data-carousel-track]');
        if (!(track instanceof HTMLElement)) return;

        const slideCount = track.children.length;
        if (slideCount < 2) return;

        const scrollToSlide = (index: number) => {
          track.scrollTo({
            left: index * track.clientWidth,
            behavior: 'smooth'
          });
        };

        const currentIndex = () => Math.round(track.scrollLeft / Math.max(track.clientWidth, 1));

        const go = (direction: number) => {
          const nextIndex = (currentIndex() + direction + slideCount) % slideCount;
          scrollToSlide(nextIndex);
        };

        let timer = window.setInterval(() => go(1), 10000);
        const stop = () => window.clearInterval(timer);
        const start = () => {
          stop();
          timer = window.setInterval(() => go(1), 10000);
        };

        carousel.querySelectorAll('[data-carousel-button]').forEach((button) => {
          button.addEventListener('click', () => {
            if (!(button instanceof HTMLElement)) return;
            const direction = button.dataset.carouselButton === 'next' ? 1 : -1;
            go(direction);
            start();
          });
        });

        carousel.addEventListener('mouseenter', stop);
        carousel.addEventListener('mouseleave', start);
        carousel.addEventListener('focusin', stop);
        carousel.addEventListener('focusout', start);
      });

      document.querySelectorAll('.classroom-card').forEach((card) => {
        card.addEventListener('toggle', () => {
          if (!(card instanceof HTMLDetailsElement) || !card.open) return;
          document.querySelectorAll('.classroom-card[open]').forEach((openedCard) => {
            if (openedCard !== card && openedCard instanceof HTMLDetailsElement) {
              openedCard.open = false;
            }
          });
        });
      });
    </script>
  </body>
</html>
