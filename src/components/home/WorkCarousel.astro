---
type WorkCollection = {
  key: string;
  title: string;
  description: string;
  slides: Array<{
    image: string;
    title: string;
    link: string;
  }>;
};

type Props = {
  collection: WorkCollection;
};

const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const hrefFor = (href: string) => `${base}${href.replace(/^\/+/, '')}`;
---

<article class="work-panel">
  <div class="work-panel__header">
    <div>
      <h3>{collection.title}</h3>
      <p>{collection.description}</p>
    </div>
  </div>
  <div class="work-gallery">
    {collection.slides.map((slide) => (
      <a class="work-artwork" href={hrefFor(slide.link)}>
        <img src={asset(slide.image)} alt={`${slide.title}｜${collection.title}作品`} width="1000" height="760" loading="lazy" decoding="async" />
        <span>{slide.title}</span>
      </a>
    ))}
  </div>
</article>
