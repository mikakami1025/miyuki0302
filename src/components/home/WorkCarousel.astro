---
type WorkCollection = {
  key: string;
  title: string;
  description: string;
  slides: Array<{
    image: string;
    title: string;
    link: string;
  }>;
};

type Props = {
  collection: WorkCollection;
};

const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const hrefFor = (href: string) => `${base}${href.replace(/^\/+/, '')}`;
const lead = collection.slides[0];
const supporting = collection.slides.slice(1, 3);
---

<article class="work-panel">
  <a class="work-panel__image" href={asset(lead.image)} target="_blank" rel="noreferrer" aria-label={`${lead.title}，開啟大圖觀看`}>
    <img src={asset(lead.image)} alt={`${lead.title}｜${collection.title}代表作品`} width="1200" height="900" loading="lazy" decoding="async" />
  </a>
  <div class="work-panel__body">
    <p class="eyebrow">{collection.key === 'crystal-flowers' ? 'American Flower' : 'Craft Bonsai'}</p>
    <h3>{collection.title}</h3>
    <p>{collection.description}</p>
    <div class="work-panel__links" aria-label={`${collection.title}作品入口`}>
      {supporting.map((slide) => (
        <a href={asset(slide.image)} target="_blank" rel="noreferrer">
          <span>{slide.title}</span>
        </a>
      ))}
      <a href={hrefFor(lead.link)}>
        <span>閱讀相關作品故事</span>
      </a>
    </div>
  </div>
</article>
