---
type WorkCollection = {
  key: string;
  title: string;
  description: string;
  slides: Array<{
    image: string;
    title: string;
    link: string;
  }>;
};

type Props = {
  collection: WorkCollection;
};

const { collection } = Astro.props;
const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const hrefFor = (href: string) => `${base}${href.replace(/^\/+/, '')}`;
---

<article class="work-panel" data-carousel>
  <div class="work-panel__header">
    <div>
      <h3>{collection.title}</h3>
      <p>{collection.description}</p>
    </div>
    <div class="mini-actions">
      <button type="button" data-carousel-button="prev" aria-label={`${collection.title}上一張`}>‹</button>
      <button type="button" data-carousel-button="next" aria-label={`${collection.title}下一張`}>›</button>
    </div>
  </div>
  <div class="work-track" data-carousel-track>
    {collection.slides.map((slide) => (
      <a class="work-slide" href={hrefFor(slide.link)}>
        <img src={asset(slide.image)} alt={slide.title} loading="lazy" />
        <span>{slide.title}</span>
      </a>
    ))}
  </div>
</article>
