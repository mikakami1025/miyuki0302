---
import { heroSlides } from '@/data/home';
import { siteConfig } from '@/config/site';

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const featured = heroSlides[0];
const commaIndex = featured.title.indexOf('，');
const titleBeforeBreak = commaIndex >= 0 ? featured.title.slice(0, commaIndex + 1) : featured.title;
const titleAfterBreak = commaIndex >= 0 ? featured.title.slice(commaIndex + 1) : '';
---

<section class="hero" aria-label="Miyuki日本水晶花藝主視覺">
  <div class="hero__inner">
    <div class="hero-content">
      <p class="eyebrow">{featured.eyebrow}</p>
      <h1>
        {titleBeforeBreak}
        {titleAfterBreak && <><br />{titleAfterBreak}</>}
      </h1>
      <p>{featured.description}</p>
      <a class="button" href="#contact">聯絡老師</a>
    </div>
    <figure class="hero-artwork">
      <img
        src={asset(featured.image)}
        alt={`${featured.title}｜${siteConfig.shortName}作品主視覺`}
        width="960"
        height="641"
        loading="eager"
        decoding="sync"
        fetchpriority="high"
      />
      <figcaption>{siteConfig.name}</figcaption>
    </figure>
  </div>
</section>
