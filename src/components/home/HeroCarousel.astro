---
import { heroSlides } from '@/data/home';

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const hrefFor = (href: string) => href.startsWith('#') ? href : `${base}${href.replace(/^\/+/, '')}`;
---

<section class="hero" data-carousel aria-label="首頁輪播圖">
  <div class="carousel-actions">
    <button type="button" data-carousel-button="prev" aria-label="上一張">‹</button>
    <button type="button" data-carousel-button="next" aria-label="下一張">›</button>
  </div>
  <div class="hero-track" data-carousel-track>
    {heroSlides.map((slide) => (
      <article class="hero-slide" style={`--slide-image: url('${asset(slide.image)}')`}>
        <img src={asset(slide.image)} alt={slide.title} loading="eager" />
        <div class="hero-content">
          <p class="eyebrow">{slide.eyebrow}</p>
          <h1>{slide.title}</h1>
          <p>{slide.description}</p>
          <a class="button" href={hrefFor(slide.link)}>{slide.linkLabel}</a>
        </div>
      </article>
    ))}
  </div>
</section>
