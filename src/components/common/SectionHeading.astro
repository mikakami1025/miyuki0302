---
type Props = {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
};

const { eyebrow, title, description, align = 'center' } = Astro.props;
---

<div class={`section-heading section-heading--${align}`}>
  {eyebrow && <p class="eyebrow">{eyebrow}</p>}
  <h2>{title}</h2>
  {description && <p>{description}</p>}
</div>
