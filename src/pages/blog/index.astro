---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SectionHeading from '@/components/common/SectionHeading.astro';

const base = import.meta.env.BASE_URL;
const asset = (path: string) => `${base}${path.replace(/^\/+/, '')}`;
const hrefFor = (href: string) => `${base}${href.replace(/^\/+/, '')}`;
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title="Miyuki老師與學生們的作品" description="水晶花藝、工藝盆栽與課程作品文章。">
  <section class="section page-hero">
    <div class="container">
      <SectionHeading
        eyebrow="Blog"
        title="Miyuki老師與學生們的作品"
        level="h1"
      />
    </div>
  </section>
  <section class="section">
    <div class="container blog-grid">
      {posts.map((post) => (
        <article class="post-card">
          <a href={hrefFor(`blog/${post.data.slug}/`)}>
            <span class="post-image-frame">
              <img src={asset(post.data.cover)} alt={`${post.data.title}｜Miyuki日本水晶花藝作品文章封面`} width="1200" height="900" loading="lazy" decoding="async" />
            </span>
            <div>
              <p class="post-meta">
                <time datetime={post.data.date.toISOString()}>{post.data.date.toLocaleDateString('zh-TW')}</time>
                <span>{post.data.category}</span>
              </p>
              <h2>{post.data.title}</h2>
              <p>{post.data.description}</p>
              <ul class="tag-list">
                {post.data.tags.map((tag) => <li>{tag}</li>)}
              </ul>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
